{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ".opencode/plugins/graphify.js"
  ],
  "mcp": {
    "graphify-local": {
      "type": "local",
      "command": [
        "/Users/abscalibur/metaauto/.venv/bin/python",
        "-m",
        "graphify.serve",
        "/Users/abscalibur/metaauto/graphify-out/graph.json"
      ],
      "enabled": true
    },
    "obsidian-local": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bitbonsai/mcpvault@latest",
        "/Users/abscalibur/metaauto/obsidian-vault"
      ],
      "enabled": true
    }
  },
  "instructions": [
    "AGENTS.md",
    "graphify-out/GRAPH_REPORT.md"
  ]
}

